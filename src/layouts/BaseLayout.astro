---
import '../styles/global.css'
import '../styles/animations.css'
import Nav from '../components/Nav'
import WaveBackground from '../components/WaveBackground'
import en from '../i18n/en.json'
import es from '../i18n/es.json'

export interface Props {
  title?: string
}

const lang = Astro.locals.lang as string
const dict = lang === 'en' ? en : es
const { title } = Astro.props
const pageTitle = title ? `${title} | ${dict.NAV.APP_NAME}` : dict.NAV.APP_NAME
const skipLinkText = lang === 'en' ? 'Skip to content' : 'Saltar al contenido'
---

<!DOCTYPE html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={lang === 'en' ? 'Listen to radio from around the world - Thousands of live stations' : 'Escucha radio de todo el mundo - Miles de estaciones en vivo'} />
    <meta name="theme-color" content="#1a1b26" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://de1.api.radio-browser.info" crossorigin />
    <link rel="dns-prefetch" href="https://de1.api.radio-browser.info" />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen text-white flex flex-col">
    <WaveBackground client:load />
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-[var(--color-accent)] focus:text-white focus:px-4 focus:py-2 focus:rounded-lg"
    >
      {skipLinkText}
    </a>
    <Nav client:load lang={lang} />
    <main id="main" class="flex-1 pt-16 content-layer w-full max-w-full overflow-x-hidden">
      <slot />
    </main>
    <footer class="content-layer w-full max-w-full overflow-x-hidden border-t border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg-base)_92%,transparent)] backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 py-3 sm:py-6 mobile-menu-safe flex flex-col md:flex-row items-center justify-between gap-1.5 sm:gap-3 md:gap-4">
        <p class="text-[0.62rem] sm:text-sm text-[var(--color-text-muted)] text-center md:text-left leading-relaxed break-words">{dict.HOME.FOOTER.COPYRIGHT}</p>
        <div class="w-full md:w-auto flex flex-wrap items-center justify-center md:justify-end gap-x-3 gap-y-1 text-[0.62rem] sm:text-sm">
          <a href="/legal/terms" class="inline-flex items-center min-h-8 sm:min-h-10 text-[var(--color-text-muted)] hover:text-[var(--color-accent-hover)] transition-colors focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] rounded px-1.5 py-0.5">{dict.HOME.FOOTER.TERMS}</a>
          <a href="/legal/privacy" class="inline-flex items-center min-h-8 sm:min-h-10 text-[var(--color-text-muted)] hover:text-[var(--color-accent-hover)] transition-colors focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] rounded px-1.5 py-0.5">{dict.HOME.FOOTER.PRIVACY}</a>
          <a href="/legal/faq" class="inline-flex items-center min-h-8 sm:min-h-10 text-[var(--color-text-muted)] hover:text-[var(--color-accent-hover)] transition-colors focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] rounded px-1.5 py-0.5">{dict.HOME.FOOTER.FAQ}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
