---
import BaseLayout from '../layouts/BaseLayout.astro'
import es from '../i18n/es.json'
import en from '../i18n/en.json'

const lang = Astro.locals.lang as string
const dict = lang === 'en' ? en : es
const nf = dict.NOT_FOUND
---

<BaseLayout title={nf.TITLE}>
  <section class="min-h-[80dvh] flex flex-col items-center justify-center text-center px-4 py-24">
    <div class="animate-fade-in">
      <div class="inline-flex items-center justify-center w-20 h-20 md:w-24 md:h-24 rounded-3xl bg-[var(--color-accent-soft)] mb-6 md:mb-8 animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]"><path d="M18.8 4.84a3 3 0 0 0-2.12-.87H7.32a3 3 0 0 0-2.12.87L2.84 7.2a3 3 0 0 0-.87 2.12v9.36a3 3 0 0 0 .87 2.12l2.36 2.36a3 3 0 0 0 2.12.87h9.36a3 3 0 0 0 2.12-.87l2.36-2.36a3 3 0 0 0 .87-2.12V9.32a3 3 0 0 0-.87-2.12Z"/><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
      </div>
      <h1 class="text-fluid-3xl font-bold mb-4 bg-gradient-to-r from-[var(--color-accent-hover)] to-[var(--color-pink-hover)] bg-clip-text text-transparent">404</h1>
      <p class="text-fluid-lg text-[var(--color-text-secondary)] mb-8">{nf.MESSAGE}</p>
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a href="/" class="btn-primary">{nf.BTN_HOME}</a>
        <a href="/player" class="btn-secondary">{dict.NAV.PLAYER}</a>
        <a href="/search" class="btn-secondary">{dict.NAV.SEARCH}</a>
      </div>
    </div>
  </section>
</BaseLayout>
