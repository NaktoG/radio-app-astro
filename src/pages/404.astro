---
import BaseLayout from '../layouts/BaseLayout.astro'
import es from '../i18n/es.json'
import en from '../i18n/en.json'

const lang = Astro.locals.lang as string
const dict = lang === 'en' ? en : es
const nf = dict.NOT_FOUND
---

<BaseLayout title={nf.TITLE}>
  <section class="min-h-[80dvh] flex flex-col items-center justify-center text-center px-4 py-24">
    <div class="animate-fade-in">
      <div class="icon-orb mx-auto mb-6 md:mb-8 !w-20 !h-20 md:!w-24 md:!h-24 !rounded-3xl animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.9 19.1a10 10 0 1 1 14.2 0"/><path d="M8.5 15.5a5 5 0 1 1 7 0"/><path d="M12 12h.01"/><path d="M12 17v4"/><path d="M9 21h6"/></svg>
      </div>
      <h1 class="text-fluid-3xl font-bold mb-4 bg-gradient-to-r from-[var(--color-accent-hover)] to-[var(--color-pink-hover)] bg-clip-text text-transparent">404</h1>
      <p class="text-fluid-lg text-[var(--color-text-secondary)] mb-8">{nf.MESSAGE}</p>
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a href="/" class="btn-primary">{nf.BTN_HOME}</a>
        <a href="/player" class="btn-secondary">{dict.NAV.PLAYER}</a>
        <a href="/search" class="btn-secondary">{dict.NAV.SEARCH}</a>
      </div>
    </div>
  </section>
</BaseLayout>
