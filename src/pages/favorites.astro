---
import BaseLayout from '../layouts/BaseLayout.astro'
import FavoritesContainer from '../components/FavoritesContainer'
import es from '../i18n/es.json'
import en from '../i18n/en.json'

const lang = Astro.locals.lang as string
const dict = lang === 'en' ? en : es
---

<BaseLayout title={dict.FAVORITES.TITLE}>
  <section class="max-w-7xl mx-auto px-4 py-24">
    <h1 class="text-3xl font-bold mb-8 bg-gradient-to-r from-[var(--color-accent-hover)] to-[var(--color-pink-hover)] bg-clip-text text-transparent">
      {dict.FAVORITES.TITLE}
    </h1>
    <FavoritesContainer client:load />
  </section>
</BaseLayout>
