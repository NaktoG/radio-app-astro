---
import BaseLayout from '../layouts/BaseLayout.astro'
import RadioPlayer from '../components/RadioPlayer'
import es from '../i18n/es.json'
import en from '../i18n/en.json'

const lang = Astro.locals.lang as string
const dict = lang === 'en' ? en : es
---

<BaseLayout title={dict.NAV.PLAYER}>
  <section class="max-w-7xl mx-auto px-4 py-24">
    <h1 class="text-fluid-2xl font-bold mb-6 sm:mb-8 bg-gradient-to-r from-[var(--color-accent-hover)] to-[var(--color-pink-hover)] bg-clip-text text-transparent">
      {dict.NAV.PLAYER}
    </h1>
    <RadioPlayer client:load />
  </section>
</BaseLayout>
